# Ignore Q2A config file and .htaccess in development
/qa-config.php
/.htaccess
/qa-tests/phpunit-qa-config.php

# Ignore cached files
/qa-cache/*/

# Local environment overrides / secrets (symfony/dotenv); .env itself is committed
/.env.local
/.env.local.php
/.env.*.local

# Dev tool caches (vendor/ is intentionally committed, do NOT ignore it)
/.php-cs-fixer.cache
/.phpunit.result.cache
/.phpunit.cache/

# Editors / IDEs
.idea/
.vscode/

# Build & coverage artifacts
/coverage/
/build/
*.log

# Other files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
