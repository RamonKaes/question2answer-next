{
    "name": "q2a/question2answer",
    "description": "Question2Answer — open source Q&A platform (PHP 8.4+ modernization).",
    "type": "project",
    "keywords": ["q2a", "question2answer", "qa", "forum"],
    "homepage": "https://github.com/q2a/question2answer",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Gideon Greenspan and contributors",
            "homepage": "https://www.question2answer.org/",
            "role": "Original author"
        },
        {
            "name": "Ramon Kaes",
            "role": "2026 modernization maintainer"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "symfony/http-foundation": "^7.2",
        "symfony/routing": "^7.2",
        "symfony/dependency-injection": "^7.2",
        "symfony/config": "^7.2",
        "symfony/console": "^7.2",
        "symfony/event-dispatcher": "^7.2",
        "symfony/cache": "^7.2",
        "symfony/dotenv": "^7.2",
        "twig/twig": "^3.14",
        "doctrine/dbal": "^4.2",
        "doctrine/migrations": "^3.8",
        "monolog/monolog": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.4",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "Q2A\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Q2A\\Tests\\": "qa-tests/unit/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.4"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "stan": "phpstan analyse",
        "test": "phpunit",
        "check": [
            "@cs",
            "@stan",
            "@test"
        ]
    }
}
