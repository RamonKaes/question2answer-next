# Question2Answer environment configuration.
#
# Commit safe, non-secret defaults here. Put machine-specific values and
# secrets in .env.local (gitignored) — never commit real credentials.

# Application environment: dev | prod | test
APP_ENV=dev
APP_DEBUG=1

# Doctrine DBAL connection (used from the next Phase 2 step onwards).
DATABASE_URL="mysql://q2a:q2a@127.0.0.1:3306/q2a?serverVersion=8.0&charset=utf8mb4"
